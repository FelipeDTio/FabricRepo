	measure 'Scatter Plot Color Campaings' = ```
			
			VAR _maxCost = AVERAGEX(ALLSELECTED(dimCampaigns[Campaign Name]), [Cost]) 
			VAR _maxRoas = Averagex(ALLSELECTED(dimCampaigns[Campaign Name]), [ROAS]) 
			RETURN
			SWITCH(
			     TRUE(),
			     [Cost] > _maxCost && [ROAS] < _maxRoas, "#D64550", //red
			     [Cost] < _maxCost && [ROAS] > _maxRoas, "#118DFF", // blue
			     [Cost] < _maxCost && [ROAS] < _maxRoas, "#D9B300", //yellow
			     BLANK()
			     )
			```
		lineageTag: 61a27d3b-5ec7-47d3-8a2b-c385eb127a6d

	measure '_Custom Period Filter' =
			
			VAR _SelectedPeriod = SELECTEDVALUE ( PeriodsSelection[Period] )
			VAR _SliderStart = MIN ( dimCalendar_Slicer[Date])
			VAR _SliderEnd =  MAX (dimCalendar_Slicer[Date] )
			VAR _IsCM = SELECTEDVALUE ( dimKalender[IsAktuellerMonat], FALSE() )
			VAR _IsCY = SELECTEDVALUE ( dimKalender[IsAktuellesJahr], FALSE () )
			VAR _IsLM = SELECTEDVALUE ( dimKalender[IsLetzterMonat], FALSE() )
			VAR _IsLQ = SELECTEDVALUE ( dimKalender[IsLetztesQuartal], FALSE () )
			VAR _IsLY = SELECTEDVALUE ( dimKalender[IsLetztesJahr], FALSE () )
			RETURN
			SWITCH (
			    TRUE (),
			   _SelectedPeriod = "Custom" && ISBLANK(_SliderStart), BLANK(),
			    _SelectedPeriod = "Custom",
			        IF ( MAX ( dimKalender[Date] ) >= _SliderStart && MAX ( dimKalender[Date] ) <= _SliderEnd, 1, 0 ) ,
			    _SelectedPeriod = "Current Month",
			        IF ( _IsCM, 1, 0 ),
			    _SelectedPeriod = "Current Year",
			        IF ( _IsCY, 1, 0 ),
			    0
			)
		formatString: 0
		lineageTag: 56077829-b009-4072-a805-f424117ea944

	measure 'Show Top N Campaign' =
			
			VAR n = SELECTEDVALUE('TopN'[TopN], 5)
			VAR _set = TOPN(n, ALLSELECTED(dimCampaigns[Campaign Name]), [Selection 1 Variance ABS], DESC)
			RETURN
			IF(CONTAINS(_set, dimCampaigns[Campaign Name], SELECTEDVALUE(dimCampaigns[Campaign Name])),1,0)
		formatString: 0
		lineageTag: 109e47dc-a336-4a08-9890-0af526261368

