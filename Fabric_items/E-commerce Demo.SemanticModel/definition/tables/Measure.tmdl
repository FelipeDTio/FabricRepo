	measure 'Tooltip Row 1' = ```
			
			
			VAR LineOne = SELECTEDVALUE('Selection 1'[Selection 1 Order])
			VAR LineTwo = SELECTEDVALUE('Selection 2'[Selection 2 Order])
			VAR LineThree = SELECTEDVALUE('Selection 3'[Selection Order])
			
			VAR LineOneValue =
			SWITCH(
			    TRUE(),
			    LineOne = 0, [Impressions],
			    LineOne = 1, [Clicks],
			    LineOne = 2, [Conversions],
			    LineOne = 3, [Cost],
			    LineOne = 4, [Conversion Value],
			    LineOne = 5, [CPA],
			    LineOne = 6, [CTR],
			    LineOne = 7, [CVR],
			    LineOne = 8, [ROAS]
			)
			
			VAR _LineTwoOrder =
			
			        IF( LineTwo <> 10, LineTwo, 
			            IF(LineThree <> 10, LineThree, BLANK())
			    )
			
			VAR LineTwoValue =
			IF(
			    _LineTwoOrder <> BLANK(),
			    SWITCH(
			        TRUE(),
			     LineTwo = 0, [Impressions],
			    LineTwo = 1, [Clicks],
			    LineTwo = 2, [Conversions],
			    LineTwo = 3, [Cost],
			    LineTwo = 4, [Conversion Value],
			    LineTwo = 5, [CPA],
			    LineTwo = 6, [CTR],
			    LineTwo = 7, [CVR],
			    LineTwo = 8, [ROAS]
			    )
			)
			
			VAR _LineThreeOrder =
			    SWITCH(
			        TRUE(),
			        LineTwo <> 10 && LineThree <> 10, LineThree,
			        LineTwo <> 10 && LineThree = 10 , BLANK(),
			       // LineTwo = 10 && LineThree <> 10 && LineFour <> 10, LineFour,
			        BLANK()
			    )
			
			VAR LineThreeValue =
			IF(
			    _LineThreeOrder <> BLANK(),
			  SWITCH(
			        TRUE(),
			     LineThree = 0, [Impressions],
			    LineThree = 1, [Clicks],
			    LineThree = 2, [Conversions],
			    LineThree = 3, [Cost],
			    LineThree = 4, [Conversion Value],
			    LineThree = 5, [CPA],
			    LineThree = 6, [CTR],
			    LineThree = 7, [CVR],
			    LineThree = 8, [ROAS]
			    )
			)
			
			
			RETURN
			SWITCH(
			    TRUE(),
			    MAX('Tooltip Layout'[RowLabel]) = "Row 1", LineOneValue,
			    MAX('Tooltip Layout'[RowLabel]) = "Row 2", LineTwoValue,
			    MAX('Tooltip Layout'[RowLabel]) = "Row 3", LineThreeValue,
			    MAX('Tooltip Layout'[RowLabel]) = "Row 4", [Tooltip_Linechart],
			    MAX('Tooltip Layout'[RowLabel]) = "Row 5", [Actual Date Tooltip] 
			)
			```
		lineageTag: 9c2f1f57-29d5-41c1-9332-c0aaf8c35e9e

		formatStringDefinition = ```
				
				
				VAR LineOne = SELECTEDVALUE('Selection 1'[Selection 1 Order])
				VAR LineTwo = SELECTEDVALUE('Selection 2'[Selection 2 Order])
				VAR LineThree = SELECTEDVALUE('Selection 3'[Selection Order])
				
				VAR LineOneValue =
				SWITCH(
				    TRUE(),
				    LineOne = 0, "#,##0",
				    LineOne = 1, "#,##0",
				    LineOne = 2, "#,##0",
				    LineOne = 3, "$#,##0",
				    LineOne = 4, "$#,##0",
				    LineOne = 5, "$#,##0.00",
				    LineOne = 6, "#.0%",
				    LineOne = 7, "#.0%",
				    LineOne = 8, "#,##0.0"
				)
				
				VAR _LineTwoOrder =
				
				        IF( LineTwo <> 10, LineTwo, 
				            IF(LineThree <> 10, LineThree, BLANK())
				    )
				
				VAR LineTwoValue =
				IF(
				    _LineTwoOrder <> BLANK(),
				    SWITCH(
				        TRUE(),
				     LineTwo = 0, "#,##0",
				    LineTwo = 1, "#,##0",
				    LineTwo = 2, "#,##0",
				    LineTwo = 3, "#,##0€",
				    LineTwo = 4, "$#,##0",
				    LineTwo = 5, "$#,##0.00",
				    LineTwo = 6, "#.0%",
				    LineTwo = 7, "#.0%",
				    LineTwo = 8, "#,##0.0"
				    )
				)
				
				VAR _LineThreeOrder =
				    SWITCH(
				        TRUE(),
				        LineTwo <> 10 && LineThree <> 10, LineThree,
				        LineTwo <> 10 && LineThree = 10 , BLANK(),
				       // LineTwo = 10 && LineThree <> 10 && LineFour <> 10, LineFour,
				        BLANK()
				    )
				
				VAR LineThreeValue =
				IF(
				    _LineThreeOrder <> BLANK(),
				  SWITCH(
				        TRUE(),
				     LineThree = 0, "#,##0",
				    LineThree = 1, "#,##0",
				    LineThree = 2, "#,##0",
				    LineThree = 3, "#,##0€",
				    LineThree = 4, "$#,##0",
				    LineThree = 5, "$#,##0.00",
				    LineThree = 6, "#.0%",
				    LineThree = 7, "#.0%",
				    LineThree = 8, "#,##0.0"
				    )
				)
				
				
				RETURN
				SWITCH(
				    TRUE(),
				    MAX('Tooltip Layout'[RowLabel]) = "Row 1", LineOneValue,
				    MAX('Tooltip Layout'[RowLabel]) = "Row 2", LineTwoValue,
				    MAX('Tooltip Layout'[RowLabel]) = "Row 3", LineThreeValue)
				   // MAX('Tooltip Layout'[RowLabel]) = "Row 4", [Tooltip_Linechart],
				   // MAX('Tooltip Layout'[RowLabel]) = "Row 5", [Actual Date Tooltip] 
				
				```

	measure Tooltip_Linechart =
			
			VAR _Jahr = SELECTEDVALUE('dimKalender'[Jahr])
			VAR _Month =  SELECTEDVALUE('dimKalender'[Monat])
			VAR _Quarter = SELECTEDVALUE('dimKalender'[Quartal])
			VAR _Week = SELECTEDVALUE('dimKalender'[Woche])
			
			RETURN
			SWITCH(TRUE(),
			    NOT ISBLANK(_Week), "KW" & _Week & " " & _Jahr,
			    NOT ISBLANK(_Month), _Month & " " & _Jahr,
			    NOT ISBLANK(_Quarter),  _Quarter & " " & _Jahr
			)
		lineageTag: abd5756a-56a2-49e0-b9b8-7eda87a75f0f

	measure 'Tooltip_Linechart date' =
			
			VAR _Jahr = SELECTEDVALUE('dimKalender'[Jahr])
			VAR _Month =  SELECTEDVALUE('dimKalender'[Monat])
			VAR _Quarter = SELECTEDVALUE('dimKalender'[Quartal])
			VAR _Week = SELECTEDVALUE('dimKalender'[Woche])
			
			RETURN
			SWITCH(TRUE(),
			    NOT ISBLANK(_Week), LASTNONBLANK(dimKalender[WocheJahr],0),
			    NOT ISBLANK(_Month), LASTNONBLANK(dimKalender[MonthYear],0),
			    NOT ISBLANK(_Quarter), LASTNONBLANK(dimKalender[QuartalJahr],0)
			)
		formatString: General Date
		lineageTag: 19df1b20-d4b5-45e1-acce-d17d854a05ac

	measure 'Actual Date Tooltip' =
			
			VAR _StartDate = MIN(dimKalender[Date])
			VAR _EndDate = MAX(dimKalender[Date])
			RETURN
			    FORMAT(_StartDate,"DD/MM/YYYY") & " - " & FORMAT(_EndDate,"DD/MM/YYYY")
		lineageTag: ce424758-0364-48b0-8bb0-6d17e619dc3b

