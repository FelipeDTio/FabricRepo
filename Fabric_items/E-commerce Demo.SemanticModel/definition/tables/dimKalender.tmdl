	partition dimKalender = calculated
		mode: import
		source = ```
				
				
				VAR _MinDate =  MIN( factCampaigns[Date] )
				VAR _MaxDate =  MAX( factCampaigns[Date] )
				VAR _Dates = CALENDAR( _MinDate, _MaxDate )
				VAR _MaxYear = YEAR(_MaxDate)
				VAR _MaxMonth = MONTH(_MaxDate)
				VAR _MaxQuarter = QUARTER(_MaxDate)
				
				RETURN
				ADDCOLUMNS(
				    _Dates,
				    "Jahr", YEAR([Date]),
				    "Monatsnummer", MONTH([Date]),
				    "Monat", FORMAT([Date], "MMMM", "de-DE" ),
				    "Monat Kurz", FORMAT([Date], "MMM", "de-DE" ),
				    "Monat Initial", LEFT(FORMAT([Date], "MMMM"), 1),
				    "Quartal", "Q" & FORMAT([Date], "Q"),
				    "Jahr-Monat", FORMAT([Date], "YYYY-MM"),
				    "Monat-Jahr", FORMAT([Date], "mmm YYYY"),
				    "Wochentag Nummer", WEEKDAY([Date], 2),  -- 1=Sonntag, 2=Montag
				    "Wochentag", FORMAT([Date], "dddd", "de-DE" ),
				    "Wochenende", IF(WEEKDAY([Date], 2) > 5, TRUE, FALSE),
				    "MonthYear", DATE( YEAR( [Date] ), MONTH( [Date] ), 1), 
				    "QuartalJahr", EOMONTH([Date], 3 * (INT((MONTH([Date]) - 1) / 3) + 1) - MONTH([Date])),
				    "Woche", WEEKNUM( [Date], 21 ),
				    "WocheJahr", [Date]+1-WEEKDAY([Date]-1),
				    "Woche Chart", "KW" & WEEKNUM( [Date], 21 ) & " " & YEAR([Date]),
				    "Monat Chart" , FORMAT([Date], "MMM", "de-DE" ) & " " & YEAR([Date]),
				    "Quartal Chart",  "Q" & FORMAT([Date], "Q") & " " &  YEAR([Date]),
				    "IsAktuellerMonat", YEAR([Date]) = _MaxYear && MONTH([Date]) = _MaxMonth,
				    "IsLetzterMonat",
				        (YEAR([Date]) = _MaxYear && MONTH([Date]) = _MaxMonth - 1)
				        || (_MaxMonth = 1 && YEAR([Date]) = _MaxYear - 1 && MONTH([Date]) = 12),
				    "IsVorVorMonat",
				        (YEAR([Date]) = _MaxYear && MONTH([Date]) = _MaxMonth - 2)
				        || (_MaxMonth = 1 && YEAR([Date]) = _MaxYear - 1 && MONTH([Date]) = 11)
				        || (_MaxMonth = 2 && YEAR([Date]) = _MaxYear - 1 && MONTH([Date]) = 12),
				    "IsAktuellesJahr", YEAR([Date]) = _MaxYear,
				    "IsLetztesJahr", YEAR([Date]) = _MaxYear - 1,
				    "IsVorVorJahr", YEAR([Date]) = _MaxYear - 2,
				    "IsLetztesQuartal",
				        (YEAR([Date]) = _MaxYear && QUARTER([Date]) = _MaxQuarter - 1)
				        || (_MaxQuarter = 1 && YEAR([Date]) = _MaxYear - 1 && QUARTER([Date]) = 4),
				    "IsVorVorQuartal",
				        (YEAR([Date]) = _MaxYear && QUARTER([Date]) = _MaxQuarter - 2)
				        || (_MaxQuarter = 1 && YEAR([Date]) = _MaxYear - 1 && QUARTER([Date]) = 3)
				        || (_MaxQuarter = 2 && YEAR([Date]) = _MaxYear - 1 && QUARTER([Date]) = 4))
				```

	annotation PBI_Id = 4fb106d3da974290a1a531f87ef8173f

